@page
@model MyWebApp.Pages.ContactModel

<h2>Contact Form</h2>

<form method="post">
    <div>
        <label>Name</label>
        <input asp-for="Contact.Name" />
        <span asp-validation-for="Contact.Name" style="color:red"></span>
    </div>

    <div>
        <label>Email</label>
        <input asp-for="Contact.Email" />
        <span asp-validation-for="Contact.Email" style="color:red"></span>
    </div>

    <button type="submit">Send</button>
</form>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <p style="color:green">@Model.Message</p>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}